# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP settings for email sending
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
GEORISQUES_TOKEN=

# Google OAuth2 - pour la synchronisation Google Contacts
# Créer un Client ID sur https://console.cloud.google.com/ (Application Web)
# Ajouter les origines autorisées et l'URI de redirection = APP_URL/auth/google/callback
VITE_GOOGLE_CLIENT_ID=
# Client secret optionnel (PKCE ne l'exige pas, mais requis si activé côté Google)
GOOGLE_CLIENT_SECRET=

# Supabase - frontend (clé publique, safe dans le bundle)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase - backend Express uniquement (ne jamais exposer côté client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Super-admin dashboard (propriétaire SaaS uniquement)
# Définir les deux avec l'email du propriétaire pour activer la route /admin.
SUPER_ADMIN_EMAIL=owner@example.com
VITE_SUPER_ADMIN_EMAIL=owner@example.com

# Tarification tokens IA (en EUR par million de tokens)
# Prix facturé aux tenants (inclut la marge opérateur ~3x le coût Gemini)
AI_PRICE_INPUT_PER_M=0.40
AI_PRICE_OUTPUT_PER_M=1.65

# Sentry error reporting — create a project at https://sentry.io and use its DSN.
# Leave both unset to disable reporting entirely (default for local dev).
# SENTRY_DSN: backend (Express) errors — server.ts and the agents package.
# VITE_SENTRY_DSN: frontend (browser) errors — baked into the bundle at build time.
SENTRY_DSN=
VITE_SENTRY_DSN=
