RewriteEngine On

# Redirect non-www to www
RewriteCond %{HTTP_HOST} ^archimanager\.fr$ [NC]
RewriteRule ^(.*)$ https://www.archimanager.fr/$1 [R=301,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Security headers
<IfModule mod_headers.c>
  # Allow Google Maps embed and related APIs
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://*.tile.openstreetmap.org https://*.googleapis.com https://*.gstatic.com https://data.geopf.fr; connect-src 'self' https://*.googleapis.com https://api-adresse.data.gouv.fr https://data.geopf.fr https://www.georisques.gouv.fr https://api.rnb.beta.gouv.fr https://api.bdnb.io https://*.supabase.co wss://*.supabase.co; frame-src 'self' https://maps.google.com https://www.google.com; worker-src blob:;"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
