{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@zinkh/archioffice-agents/server": ["./packages/archioffice-agents/src/server/index.ts"],
      "@zinkh/archioffice-agents/client": ["./packages/archioffice-agents/src/client/index.ts"],
      "@zinkh/archioffice-agents": ["./packages/archioffice-agents/src/types.ts"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strictNullChecks": true
  }
}
